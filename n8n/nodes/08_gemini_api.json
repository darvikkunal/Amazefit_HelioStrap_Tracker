{
  "parameters": {
    "method": "POST",
    "url": "https://openrouter.ai/api/v1/chat/completions",
    "sendHeaders": true,
    "headerParameters": {
      "parameters": [
        {
          "name": "Authorization",
          "value": "Bearer YOUR_OPENROUTER_API_KEY"
        },
        {
          "name": "HTTP-Referer",
          "value": "https://your-n8n-instance.com"
        },
        {
          "name": "X-Title",
          "value": "Kunal Health Coach"
        }
      ]
    },
    "sendBody": true,
    "specifyBody": "json",
    "jsonBody": "={\n  \"model\": \"openrouter/free\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.prompt }}\"\n    }\n  ],\n  \"max_tokens\": 2048,\n  \"transforms\": [\"middle-out\"],\n  \"route\": \"fallback\"\n}",
    "options": {}
  },
  "name": "HTTP Request",
  "type": "n8n-nodes-base.httpRequest",
  "typeVersion": 4.4,
  "retryOnFail": true,
  "executeOnce": false,
  "waitBetweenTries": 5000,
  "notes": "Calls OpenRouter API with openrouter/free model. Routes through fallback providers. Includes Authorization header, HTTP-Referer, and X-Title."
}
